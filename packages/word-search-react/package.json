  },
  "dependencies": {
    "@js-gamifications/word-search-core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.11",
    "react": "^19.1.0"
  }
}
